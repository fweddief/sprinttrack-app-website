# Copy to Railway (or local `.env`). Never commit `.env`.

# Required — from Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Required — publishable key (safe for generated browser config with RLS)
SUPABASE_PUBLISHABLE_KEY=

# Optional server-side only — never written to supabase-config.js or sent to the browser
SUPABASE_SECRET_KEY=
